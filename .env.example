# TRACaBot environment template
# Copy this file to .env and fill in the values for your Telegram group and DKG node.
# Boolean values accept: true/false, 1/0, yes/no.

# -----------------------------------------------------------------------------
# Telegram bot identity and admins
# -----------------------------------------------------------------------------

# Required. Create this with BotFather, then invite the bot to your group.
TELEGRAM_BOT_TOKEN=your-bot-token

# Optional but recommended. Comma-separated Telegram numeric IDs and/or usernames.
# Users listed here can run admin-only commands like /ban, /review, /watchlist.
# Example: TRACABOT_ADMINS=123456789,@alice,@bob
TRACABOT_ADMINS=

# -----------------------------------------------------------------------------
# DKG / OpenClaw adapter
# -----------------------------------------------------------------------------

# DKG context graph for shared scam intelligence. Keep this stable across bot
# instances that should share memory. Wallet-scoped IDs such as 0x.../tracabot
# are also supported when a project was created that way in DKG.
TRACABOT_CONTEXT_GRAPH=tracabot

# Optional. Decimal on-chain ContextGraphs ID to anchor Verified Memory publishes.
# Set this when the local context graph name is mapped to an already registered
# on-chain graph, or when DKG name registration is unavailable on the testnet.
TRACABOT_PUBLISH_CONTEXT_GRAPH_ID=

# Optional community scope metadata written into DKG events. Keep the name empty
# for private groups that should not disclose their human-readable identity.
TRACABOT_COMMUNITY_ID=
TRACABOT_COMMUNITY_NAME=
TRACABOT_COMMUNITY_TYPE=telegram_group
TRACABOT_POLICY_ID=default

# Optional stable agent identity written into shared memory events.
TRACABOT_AGENT_DID=did:dkg:agent:tracabot

# Keep openclaw-adapter unless you are intentionally developing another backend.
TRACABOT_DKG_MODE=openclaw-adapter

# Local DKG reads/writes are enabled by default. Verified Memory publishing costs
# TRAC/gas and requires a registered/funded graph, so fresh installs keep it off.
TRACABOT_DKG_READS=true
TRACABOT_DKG_WRITES=true
TRACABOT_DKG_PUBLISH_VERIFIED=false

# Local DKG daemon URL. The OpenClaw DKG adapter talks to this endpoint.
DKG_NODE_URL=http://127.0.0.1:9200

# Optional. Leave empty to auto-read ~/.dkg/auth.token when running on same host.
# Set this when the bot runs somewhere that cannot read the local DKG token file.
DKG_AUTH_TOKEN=

# Optional. Only set if the DKG OpenClaw adapter is installed in a non-standard path.
# Normal installs should leave this empty. If an old DKG release directory is present,
# point this at the current global DKG adapter, e.g.
# /usr/lib/node_modules/@origintrail-official/dkg/node_modules/@origintrail-official/dkg-adapter-openclaw/dist/index.js
OPENCLAW_DKG_ADAPTER_PATH=

# Optional. Local event/audit log. Use an absolute path for services/systemd.
TRACABOT_STORE_PATH=./data/tracabot-events.jsonl

# Set true for demos/tests that intentionally write test evidence to DKG.
# Keep false in production.
TRACABOT_TEST_MODE=false

# Selective DKG v10 Shared Memory capture for public channel scam/spam signals.
# Raw message_text is bounded and shared only for high-confidence public messages,
# such as new-member scam channel promos, token/coin promos from outside projects,
# or admin/support impersonators asking users to DM.
TRACABOT_CHANNEL_MEMORY=true
TRACABOT_CHANNEL_MEMORY_MIN_CONFIDENCE=80
TRACABOT_CHANNEL_MEMORY_MAX_TEXT_CHARS=1000

# -----------------------------------------------------------------------------
# Scam scoring and automated moderation
# -----------------------------------------------------------------------------

# Enable automatic Telegram actions. The bot still needs Telegram admin rights.
TRACABOT_AUTO_DELETE=true
TRACABOT_AUTO_RESTRICT=true
TRACABOT_AUTO_BAN=true

# Risk thresholds from 1-100. Must satisfy:
# WARN <= RESTRICT <= BAN, and ACTION is 50-100.
# Typical strict setup: warn 60, restrict 75, action 85, ban 90.
TRACABOT_WARN_THRESHOLD=60
TRACABOT_RESTRICT_THRESHOLD=75
TRACABOT_ACTION_THRESHOLD=85
TRACABOT_BAN_THRESHOLD=90

# How often proactive checks consider recent joins/messages, in minutes. Minimum 5.
TRACABOT_PROACTIVE_SCAN_MINUTES=30

# Telegram API timeout in ms. Minimum 5000.
TRACABOT_TELEGRAM_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Conversational safety replies and intent routing
# -----------------------------------------------------------------------------

# When true, TRACaBot can answer direct bot mentions and use an LLM to classify
# ambiguous natural-language intents into existing commands/tools.
TRACABOT_CONVERSATIONAL=true

# Provider options:
# - 9router: recommended hosted OpenAI-compatible route for Telegram conversations.
# - auto/openclaw/openclaw-auto: discover OpenClaw OAuth/model/gateway config.
# - http/direct/openai/openrouter/local: use TRACABOT_LLM_BASE_URL or provider default.
# - off: no LLM; deterministic templates and slash commands still work.
TRACABOT_LLM_PROVIDER=9router

# 9router example:
# TRACABOT_LLM_PROVIDER=9router
# TRACABOT_LLM_BASE_URL=https://api.9router.com
# TRACABOT_LLM_API_KEY=your-9router-key
# TRACABOT_LLM_MODEL=openai/gpt-4o-mini

# Direct/local OpenAI-compatible endpoint example:
# TRACABOT_LLM_PROVIDER=http
# TRACABOT_LLM_BASE_URL=http://127.0.0.1:11434
# TRACABOT_LLM_MODEL=llama3.1
TRACABOT_LLM_BASE_URL=
TRACABOT_LLM_API_KEY=
# Small/fast is enough: TRACaBot uses the model for short replies and intent JSON,
# not deep long-form reasoning. Raise this only if you need stronger classification.
TRACABOT_LLM_MODEL=openai/gpt-4o-mini

# Optional. Leave empty for ~/.openclaw/openclaw.json.
OPENCLAW_CONFIG_PATH=

# Minimum risk confidence needed before conversational replies use stronger scam language.
TRACABOT_CONVERSATION_MIN_CONFIDENCE=60

# Minimum confidence for proactive public safety replies.
TRACABOT_PROACTIVE_REPLY_THRESHOLD=75

# Per-chat conversation rate limit in seconds. Set 0 to disable rate limiting.
TRACABOT_CONVERSATION_RATE_LIMIT_SECONDS=60

# Max generated reply length. Valid range: 160-2000.
TRACABOT_CONVERSATION_MAX_CHARS=700

# Local/Shared Working Memory learning policy for conversation artifacts.
TRACABOT_WM_ARTIFACTS=true
TRACABOT_WM_ARTIFACT_SHARE_LOW_CONFIDENCE=false
TRACABOT_WM_ARTIFACT_REDACT=true
TRACABOT_WM_ARTIFACT_MIN_CONFIDENCE=40
TRACABOT_WM_ARTIFACT_MAX_TEXT_CHARS=700

# Optional OpenClaw workspace path and learning-loop tuning for local deployments.
OPENCLAW_WORKSPACE=
TRACABOT_LEARNING_LOOP_INTERVAL_MS=300000
TRACABOT_LEARNING_LOOP_LIMIT=25

# Rare proactive education posts. Keep the interval high to avoid token waste.
TRACABOT_DAILY_SAFE_TIP_INTERVAL_HOURS=0
TRACABOT_ARTEFACT_REVIEW_THRESHOLD=70
TRACABOT_PROACTIVE_ALERT_CROSS_GROUP=true

# DKG read timeout. Slow queries enter a short cooldown so commands stay responsive.
TRACABOT_DKG_QUERY_TIMEOUT_MS=4000

# Drop pending Telegram updates on startup to avoid replaying stale moderation
# callbacks after downtime. Set false only if you prefer processing queued updates.
TRACABOT_DROP_PENDING_UPDATES_ON_START=true

# Optional write token required by the local TRACaBot skill service for privileged
# review writes. Leave empty unless you expose that service to other tools.
TRACABOT_SKILL_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Join challenge / anti-bot onboarding
# -----------------------------------------------------------------------------

# When true, low-risk new members must complete a DKG challenge before normal chat.
TRACABOT_JOIN_CHALLENGE=false

# Options: memory-card, qa, or ual.
# memory-card: Telegram-native inline quiz about TRACaBot shared memory.
# qa: ask a rotating question whose answer is in your challenge Knowledge Asset.
# ual: ask the user to submit a valid DKG Knowledge Asset UAL.
TRACABOT_JOIN_CHALLENGE_MODE=memory-card

# Optional DKG Explorer/asset URL shown in the challenge. Recommended for qa mode.
TRACABOT_JOIN_CHALLENGE_ASSET_URL=

# JSON array of challenge questions. Answers are matched case/punctuation-insensitively.
# Keep this on one line for .env parsers.
TRACABOT_JOIN_CHALLENGE_QA_BANK='[{"id":"signal-color","question":"What is the signal color?","answers":["amber"]},{"id":"memory-phrase","question":"What is the memory phrase?","answers":["shared trail"]},{"id":"safety-animal","question":"What is the safety animal?","answers":["lobster"]},{"id":"checkpoint-word","question":"What is the checkpoint word?","answers":["atlas"]},{"id":"guard-phrase","question":"What is the guard phrase?","answers":["quiet graph"]},{"id":"community-marker","question":"What is the community marker?","answers":["relay"]},{"id":"motto","question":"Complete the motto: stay on ____. ","answers":["track","trac","trac(k)"]}]'

# Challenge timeout in seconds. Valid range: 15-900.
TRACABOT_JOIN_CHALLENGE_TTL_SECONDS=120

# Failed answer/UAL attempts before applying the timeout action. Valid range: 1-20.
TRACABOT_JOIN_CHALLENGE_MAX_ATTEMPTS=3

# Repeated failed join challenges across aliases/users before shared pattern memory.
TRACABOT_JOIN_CHALLENGE_REPEAT_FAILURE_THRESHOLD=2
TRACABOT_JOIN_CHALLENGE_REPEAT_BAD_ATTEMPT_THRESHOLD=3

# Options: kick, ban, mute. Applied when a user fails/ignores the challenge.
TRACABOT_JOIN_CHALLENGE_ACTION=kick

# Cleanup challenge messages after success/bad attempts.
TRACABOT_JOIN_CHALLENGE_DELETE_ON_PASS=true
TRACABOT_JOIN_CHALLENGE_DELETE_BAD_ATTEMPTS=true

# Validate submitted UALs through DKG when using ual mode.
TRACABOT_JOIN_CHALLENGE_DKG_VALIDATE=true

# -----------------------------------------------------------------------------
# Ephemeral bot message cleanup
# -----------------------------------------------------------------------------

# Automatically delete noisy bot replies/challenge messages after TTLs.
TRACABOT_AUTO_DELETE_BOT_MESSAGES=true

# TTLs in seconds. Bot/success min 5; challenge min 15; max 86400.
TRACABOT_BOT_MESSAGE_TTL_SECONDS=60
TRACABOT_CHALLENGE_MESSAGE_TTL_SECONDS=120
TRACABOT_SUCCESS_MESSAGE_TTL_SECONDS=45
