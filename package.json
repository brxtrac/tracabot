{
  "name": "tracabot",
  "version": "1.0.0",
  "description": "Telegram anti-scam agent that uses OriginTrail DKG v10 Working Memory, Shared Working Memory, and optional Verified Memory.",
  "homepage": "https://github.com/brxtrac/tracabot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brxtrac/tracabot.git"
  },
  "bugs": {
    "url": "https://github.com/brxtrac/tracabot/issues"
  },
  "type": "module",
  "bin": {
    "tracabot": "bin/tracabot.js",
    "tracabot-skill": "bin/tracabot-skill.js",
    "tracabot-openclaw-learning-loop": "bin/openclaw-learning-loop.js"
  },
  "scripts": {
    "start": "node ./bin/tracabot.js",
    "demo": "node ./scripts/demo-roundtrip.js",
    "skill": "node ./bin/tracabot-skill.js",
    "test:commands": "node ./scripts/test-command-loop.js",
    "test": "node --test test/*.test.js",
    "check:release": "npm test && npm run test:commands && npm run audit:production && npm pack --dry-run",
    "audit:production": "npm audit --omit=dev"
  },
  "keywords": [
    "origintrail",
    "dkg",
    "dkg-v10",
    "openclaw",
    "telegram",
    "anti-scam",
    "shared-memory",
    "context-graph"
  ],
  "author": "brxtrac",
  "license": "MIT",
  "engines": {
    "node": ">=22.20.0"
  },
  "files": [
    ".env.example",
    "bin",
    "docs/TRACABOT_CHALLENGE_ASSET.md",
    "docs/TRACABOT_CHALLENGE_ASSET.ttl",
    "docs/DEMO.md",
    "docs/DESIGN_BRIEF.md",
    "docs/PR_BODY.md",
    "docs/REGISTRY_ENTRY.md",
    "docs/TESTING.md",
    "docs/TRACABOT_ONTOLOGY.md",
    "docs/tracabot.service.example",
    "docs/demo",
    "scripts",
    "src",
    "skills",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "AGENT_INSTALL.md"
  ]
}
